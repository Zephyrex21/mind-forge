PORT=3001
NODE_ENV=development

# MongoDB (Atlas free tier works fine — create a cluster at mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mindforge?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# AI
GEMINI_API_KEY=your_gemini_api_key_here

# CORS — must be the exact deployed frontend origin (no trailing slash),
# e.g. https://your-app.vercel.app. Wrong value here silently breaks
# cross-origin cookies even if everything else is correct.
CORS_ORIGIN=http://localhost:5173

# Set to "true" in production (frontend and backend on different domains,
# e.g. Vercel + Render). This makes the auth cookie use SameSite=None;
# Secure, which is REQUIRED for cross-site cookies to be sent at all —
# without it, login appears to succeed but every following request looks
# logged out, because the browser silently drops the cookie.
# Keep "false" for local dev (same-site localhost, no HTTPS needed).
COOKIE_SECURE=false
