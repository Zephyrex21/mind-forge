PORT=3001
NODE_ENV=development

# MongoDB (Atlas free tier works fine — create a cluster at mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mindforge?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# AI
GEMINI_API_KEY=your_gemini_api_key_here

# CORS — must be the exact deployed frontend origin (no trailing slash),
# e.g. https://your-app.vercel.app. Wrong value here silently breaks
# cross-origin cookies even if everything else is correct.
CORS_ORIGIN=http://localhost:5173

# Note: there is no COOKIE_SECURE setting anymore — whether the auth cookie
# uses SameSite=None; Secure (required for cross-site setups like Vercel +
# Render) is now detected automatically per-request from whether it actually
# arrived over HTTPS, so there's nothing to misconfigure here.

# Error tracking (optional) — if set, unexpected server errors (5xx) are
# reported to Sentry in addition to the structured console logs. Leave unset
# and the app runs fine with console-only logging; nothing depends on this
# being configured. Get a DSN by creating a free project at sentry.io.
# SENTRY_DSN=
