PORT=3001
NODE_ENV=development

# MongoDB (Atlas free tier works fine — create a cluster at mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mindforge?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# AI
GEMINI_API_KEY=your_gemini_api_key_here

# CORS
CORS_ORIGIN=http://localhost:5173

# Set to "true" once deployed behind HTTPS so auth cookies get the Secure flag
COOKIE_SECURE=false
